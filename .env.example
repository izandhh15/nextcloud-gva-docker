# ==============================================================================
# TEMPLATE DE CONFIGURACIÓN NEXTCLOUD + LDAP GVA
# ==============================================================================
# Instrucciones: 
# 1. Copia este archivo: cp .env.example .env
# 2. Rellena los datos en el nuevo archivo .env
# ==============================================================================

# --- BASE DE DATOS (MariaDB) ---
# Contraseña del superusuario de la base de datos. Inventa una fuerte.
MYSQL_ROOT_PASSWORD=pon_aqui_una_clave_maestra

# Nombre de la base de datos que usará Nextcloud.
MYSQL_DATABASE=nextcloud

# Usuario de la base de datos para Nextcloud.
MYSQL_USER=nextcloud

# Contraseña para el usuario 'nextcloud'. Inventa una diferente a la de root para mayor seguridad.
MYSQL_PASSWORD=pon_aqui_una_clave_para_db

# --- ADMINISTRADOR DE NEXTCLOUD ---
# El usuario que usarás para entrar la primera vez en la web.
NEXTCLOUD_ADMIN_USER=admin

# Contraseña del administrador web. ¡No la olvides!
NEXTCLOUD_ADMIN_PASSWORD=pon_aqui_tu_clave_web

# --- CONFIGURACIÓN LDAP GVA (Servidor Central) ---
# Dirección del servidor LDAP de educación. No suele cambiar.
LDAP_HOST=ldapad.edu.gva.es

# DN del Agente (Usuario de consulta):
# Es el usuario que "lee" el servidor. 
# PISTA: Suele ser 'cn=consulta_DA,ou=educacion,dc=edu,dc=gva,dc=es'
LDAP_BIND_DN=cn=consulta_DA,ou=educacion,dc=edu,dc=gva,dc=es

# Contraseña del Agente (LDAP_BIND_DN):
# PISTA: Es la clave del usuario de consulta. Si no la sabes, suele estar 
# configurada en el archivo /etc/sssd/sssd.conf del servidor del centro.
LDAP_PASSWORD=pon_aqui_la_clave_de_consulta

# Base de búsqueda: Indica dónde buscar los usuarios.
LDAP_BASE=dc=edu,dc=gva,dc=es

# Grupo de centro (EL MÁS IMPORTANTE):
# Indica el grupo de profesores que pueden entrar.
# PISTA: Sigue el formato 'cn=GRP_CODIGOCENTRO,ou=educacion,dc=edu,dc=gva,dc=es'
# Ejemplo para un centro con código 46026160: cn=GRP_46026160,ou=educacion,dc=edu,dc=gva,dc=es
LDAP_GROUP=cn=GRP_TUCODIGOCENTRO,ou=educacion,dc=edu,dc=gva,dc=es
